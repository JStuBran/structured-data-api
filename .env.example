# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-...

# Your wallet address to receive x402 payments (Base USDC)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Public URL of your deployed service (used in 402 response)
SERVICE_URL=https://structured-data-api.up.railway.app

# Set to "false" to disable payment checks locally
PAYMENT_REQUIRED=true
